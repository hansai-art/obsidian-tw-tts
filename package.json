{
	"name": "obsidian-tw-tts",
	"version": "0.1.0",
	"description": "Read your notes aloud in Chinese using built-in system voices, with sentence-by-sentence highlight follow. Works on macOS, Windows, iOS (Android best-effort). UI in Traditional Chinese.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "NODE_NO_WARNINGS=1 tsx --tsconfig tsconfig.test.json --test tests/*.test.ts"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"tts",
		"text-to-speech",
		"chinese",
		"accessibility"
	],
	"author": "Hans Lin",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^24.0.0",
		"esbuild": "^0.28.0",
		"obsidian": "^1.5.8",
		"tslib": "2.6.2",
		"tsx": "^4.20.6",
		"typescript": "5.3.3"
	}
}
